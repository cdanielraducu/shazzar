default_platform(:android)

# ─────────────────────────────────────────────
# Shared
# ─────────────────────────────────────────────

lane :test do
  sh("cd .. && yarn test --passWithNoTests")
end

# ─────────────────────────────────────────────
# Android
# ─────────────────────────────────────────────

platform :android do

  desc "Run tests only — use on PRs before a full build"
  lane :verify do
    test
  end

  desc "Build a signed release AAB"
  lane :build do
    signing_vars = %w[ANDROID_KEYSTORE_PATH ANDROID_STORE_PASSWORD ANDROID_KEY_ALIAS ANDROID_KEY_PASSWORD]
    missing = signing_vars.select { |v| ENV[v].nil? || ENV[v].empty? }
    UI.important("WARNING: Missing signing env vars: #{missing.join(', ')}. The AAB will be unsigned and cannot be uploaded to Play Store. See README Phase 4 and scripts/setup-play-store.md.") unless missing.empty?
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "ANDROID_UPLOAD_STORE_FILE"     => ENV["ANDROID_KEYSTORE_PATH"],
        "ANDROID_UPLOAD_STORE_PASSWORD" => ENV["ANDROID_STORE_PASSWORD"],
        "ANDROID_UPLOAD_KEY_ALIAS"      => ENV["ANDROID_KEY_ALIAS"],
        "ANDROID_UPLOAD_KEY_PASSWORD"   => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
  end

  desc "Upload a pre-built AAB to Play Store (internal track)"
  lane :deploy do |options|
    aab_path = options[:aab] || UI.user_error!("Pass aab: e.g. aab:\"android/app/build/outputs/bundle/release/app-release.aab\"")
    json_key = ENV["PLAY_STORE_JSON_KEY_PATH"]
    UI.user_error!("PLAY_STORE_JSON_KEY_PATH is not set. See scripts/setup-play-store.md for setup instructions.") if json_key.nil? || json_key.empty?
    UI.user_error!("PLAY_STORE_JSON_KEY_PATH points to a missing file: #{json_key}") unless File.exist?(json_key)
    upload_to_play_store(
      track: "internal",
      aab: aab_path,
      json_key: json_key,
    )
  end

  desc "Validate Play Store credentials without uploading anything"
  lane :validate_play_connection do
    json_key = ENV["PLAY_STORE_JSON_KEY_PATH"]
    UI.user_error!("PLAY_STORE_JSON_KEY_PATH is not set. See scripts/setup-play-store.md for setup instructions.") if json_key.nil? || json_key.empty?
    UI.user_error!("PLAY_STORE_JSON_KEY_PATH points to a missing file: #{json_key}") unless File.exist?(json_key)
    upload_to_play_store(
      validate_only: true,
      json_key: json_key,
    )
    UI.success("Play Store credentials validated successfully.")
  end

  desc "Test, bump, build, and deploy to Play Store (internal track)"
  lane :ship do |options|
    test
    bump(version: options[:version])
    build
    deploy(aab: lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH])
  end

  desc "Bump versionCode and versionName, then commit"
  lane :bump do |options|
    version = options[:version] || UI.user_error!("Pass version: e.g. version:\"1.1.0\"")
    build_file = "../android/app/build.gradle"

    content = File.read(build_file)
    current_code = content.match(/versionCode\s+(\d+)/)[1].to_i
    new_code = current_code + 1

    content = content
      .gsub(/(\bversionCode\s+)\d+/, "\\1#{new_code}")
      .gsub(/(\bversionName\s+")[^"]*"/, "\\1#{version}\"")

    File.write(build_file, content)
    UI.success("Bumped to versionName #{version} / versionCode #{new_code}")

    git_add(path: build_file)
    git_commit(path: build_file, message: "chore: bump version to #{version} (#{new_code})")
  end

end

